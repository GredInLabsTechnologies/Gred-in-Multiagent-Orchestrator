# maturin / pyo3 / setuptools-rust cross-compile to Android requires the
# Android API level to be available in the environment. Without it,
# maturin pep517 fails with "Failed to determine Android API level".
#
# 24 is the modern minimum (Android 7.0+, covers ~99% of devices in 2026).
# Override at the build invocation if a stricter floor is required.
ANDROID_API_LEVEL=24
ANDROID_PLATFORM=android-24
