# ══════════════════════════════════════════════════════════════
# GIMO Monorepo — Environment Variables
# ══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in the values.
# For apps/web, also copy apps/web/.env.example to apps/web/.env.local

# ── Orchestrator Backend ──────────────────────────────────────
# ORCH_TOKEN se autogenera si no existe un .env (ver scripts de arranque).
ORCH_TOKEN=
ORCH_PORT=9325
DEBUG=false
ORCH_APP_MCP_PROFILE=safe
ORCH_APP_MCP_STREAMABLE_HTTP=true

# ── AI Provider API Keys ──────────────────────────────────────
# Configure at least one provider to use GIMO
# Priority: Anthropic > OpenAI > Groq > Ollama (local, no key needed)
#
# Anthropic (Claude models: Haiku 4.5, Sonnet 4.5/4.6, Opus 4.6)
# Get your API key at: https://console.anthropic.com/api-keys
ANTHROPIC_API_KEY=

# OpenAI (GPT models: GPT-4, GPT-4 Turbo, GPT-5.4)
# Get your API key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Groq (Fast inference for supported models)
# Get your API key at: https://console.groq.com
GROQ_API_KEY=

# Ollama (Local models - no API key needed)
# Download at: https://ollama.com
# After installing, Ollama runs locally on http://localhost:11434
# No configuration needed if running locally

# Google AI (Gemini models: Gemini 3.1 Pro)
# Get your API key at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# License gate (GIMO Web)
ORCH_LICENSE_KEY=
ORCH_LICENSE_URL=https://gimo-web.vercel.app/api/license/validate
ORCH_LICENSE_PUBLIC_KEY=
ORCH_LICENSE_GRACE_DAYS=7
ORCH_LICENSE_RECHECK_HOURS=24

# Security: keep disabled in production.
ORCH_LICENSE_ALLOW_DEBUG_BYPASS=false
ORCH_TEST_ACTOR=
ORCH_TEST_TOKEN=

# Firebase SSO bridge (Fase 2)
GIMO_WEB_URL=https://gimo-web.vercel.app
GIMO_INTERNAL_KEY=

# ── GIMO Web (apps/web) ──────────────────────────────────────
# See apps/web/.env.example for the full list of web-specific variables.
# Key variables: NEXT_PUBLIC_FIREBASE_*, STRIPE_*, LICENSE_SIGNING_PRIVATE_KEY
