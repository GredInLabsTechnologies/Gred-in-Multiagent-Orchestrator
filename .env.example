# ══════════════════════════════════════════════════════════════
# GIMO Monorepo — Environment Variables
# ══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in the values.
# For apps/web, also copy apps/web/.env.example to apps/web/.env.local

# ── Orchestrator Backend ──────────────────────────────────────
# ORCH_TOKEN se autogenera si no existe un .env (ver scripts de arranque).
ORCH_TOKEN=
ORCH_PORT=9325
DEBUG=false

# License gate (GIMO Web)
ORCH_LICENSE_KEY=
ORCH_LICENSE_URL=https://gimo-web.vercel.app/api/license/validate
ORCH_LICENSE_PUBLIC_KEY=
ORCH_LICENSE_GRACE_DAYS=7
ORCH_LICENSE_RECHECK_HOURS=24

# Security: keep disabled in production.
ORCH_LICENSE_ALLOW_DEBUG_BYPASS=false
ORCH_TEST_ACTOR=
ORCH_TEST_TOKEN=

# Firebase SSO bridge (Fase 2)
GIMO_WEB_URL=https://gimo-web.vercel.app
GIMO_INTERNAL_KEY=

# ── GIMO Web (apps/web) ──────────────────────────────────────
# See apps/web/.env.example for the full list of web-specific variables.
# Key variables: NEXT_PUBLIC_FIREBASE_*, STRIPE_*, LICENSE_SIGNING_PRIVATE_KEY
